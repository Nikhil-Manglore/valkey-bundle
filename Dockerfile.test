ARG BASE_IMAGE
FROM ${BASE_IMAGE}

# Install additional test dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    redis-tools \
    && rm -rf /var/lib/apt/lists/*

# Install test frameworks
RUN pip3 install pytest redis

# Copy test scripts
COPY tests/ /tests/

CMD ["python3", "-m", "pytest", "/tests/"]
